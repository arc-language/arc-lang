{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Arc",
	"scopeName": "source.arc",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#chars"
		},
		{
			"include": "#definitions"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#types"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#operators"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.block.arc",
					"begin": "/\\*",
					"end": "\\*/"
				},
				{
					"name": "comment.line.double-slash.arc",
					"begin": "//",
					"end": "$"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.arc",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.arc",
					"match": "\\\\([\"\\\\nrt0()]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})"
				}
			]
		},
		"chars": {
			"name": "string.quoted.single.arc",
			"begin": "'",
			"end": "'",
			"patterns": [
				{
					"name": "constant.character.escape.arc",
					"match": "\\\\."
				}
			]
		},
		"definitions": {
			"patterns": [
				{
					"comment": "Function definition",
					"match": "\\b(func|mutating|deinit)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.control.arc" },
						"2": { "name": "entity.name.function.arc" }
					}
				},
				{
					"comment": "Class/Struct/Enum definition",
					"match": "\\b(struct|class|enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.control.arc" },
						"2": { "name": "entity.name.type.class.arc" }
					}
				},
				{
					"comment": "Namespace definition",
					"match": "\\b(namespace)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.other.arc" },
						"2": { "name": "entity.name.namespace.arc" }
					}
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.arc",
					"match": "\\b(if|else|switch|case|default|for|while|in|break|continue|return|defer|try|throw|except|finally|await|async)\\b"
				},
				{
					"name": "keyword.other.arc",
					"match": "\\b(import|namespace|extern|mutating|deinit|self)\\b"
				},
				{
					"name": "storage.modifier.arc",
					"match": "\\b(let|const|static)\\b"
				},
				{
					"name": "keyword.declaration.arc",
					"match": "\\b(func|struct|class|enum)\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "storage.type.primitive.arc",
					"match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64|usize|isize|float32|float64|byte|bool|char|string|void|array)\\b"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.arc",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.language.null.arc",
					"match": "\\b(null)\\b"
				},
				{
					"name": "constant.numeric.binary.arc",
					"match": "\\b0[bB][01][01_]*\\b"
				},
				{
					"name": "constant.numeric.hex.arc",
					"match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
				},
				{
					"name": "constant.numeric.octal.arc",
					"match": "\\b0[oO][0-7][0-7_]*\\b"
				},
				{
					"name": "constant.numeric.float.arc",
					"match": "(\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?|[0-9][0-9_]*[eE][+-]?[0-9_]+|\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?)"
				},
				{
					"name": "constant.numeric.decimal.arc",
					"match": "\\b[0-9][0-9_]*\\b"
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"comment": "Intrinsics and built-ins",
					"name": "support.function.builtin.arc",
					"match": "\\b(alloca|cast|syscall|sizeof|alignof|memset|memcpy|memmove|strlen|memchr|va_start|va_arg|va_end|raise|memcmp|bit_cast|slice)\\b"
				},
				{
					"comment": "Function calls",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "entity.name.function.call.arc" }
					}
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.arc",
					"match": "(\\->|=>|\\.\\.|\\.\\.\\.|==|!=|<=|>=|&&|\\|\\||\\+=|\\-=|\\*=|/=|%=|\\|=|&=|\\^=|\\+\\+|\\-\\-|\\+|\\-|\\*|/|%|<|>|!|&|\\||\\^|~|@|=)"
				}
			]
		}
	}
}