%__vector_i32 = type { ptr<i32>, i64, i64 }

@__vec_data_0 = external constant [5 x i32] [i32 1, i32 2, i32 3, i32 4, i32 5]
@.str.1 = external constant [13 x i8] [i8 66, i8 101, i8 102, i8 111, i8 114, i8 101, i8 32, i8 108, i8 111, i8 111, i8 112, i8 10, i8 0]
@.str.2 = external constant [9 x i8] [i8 73, i8 110, i8 32, i8 108, i8 111, i8 111, i8 112, i8 10, i8 0]
@.str.3 = external constant [12 x i8] [i8 65, i8 102, i8 116, i8 101, i8 114, i8 32, i8 108, i8 111, i8 111, i8 112, i8 10, i8 0]

declare external i32 @printf(ptr<u8>, ...)

define external i32 @main() {
entry:
  %vec.data = getelementptr inbounds [5 x i32], ptr<[5 x i32]> %__vec_data_0, i32 0, i32 0
  %vec.tmp = alloca %__vector_i32
  %0 = getelementptr %__vector_i32, ptr<%__vector_i32> %vec.tmp, i32 0, i32 0
  store ptr<[5 x i32]> %vec.data, ptr<%__vector_i32> %0
  %1 = getelementptr %__vector_i32, ptr<%__vector_i32> %vec.tmp, i32 0, i32 1
  store i64 5, ptr<%__vector_i32> %1
  %2 = getelementptr %__vector_i32, ptr<%__vector_i32> %vec.tmp, i32 0, i32 2
  store i64 5, ptr<%__vector_i32> %2
  %vec.init = load %__vector_i32, ptr<%__vector_i32> %vec.tmp
  %items.addr = alloca %__vector_i32
  store %__vector_i32 %vec.init, ptr<%__vector_i32> %items.addr
  %3 = getelementptr inbounds [13 x i8], ptr<[13 x i8]> %.str.1, i32 0, i32 0
  %4 = call i32 @printf(ptr<[13 x i8]> %3)
  %5 = load %__vector_i32, ptr<%__vector_i32> %items.addr
  %6 = getelementptr %__vector_i32, ptr<%__vector_i32> %items.addr, i32 0, i32 1
  %vec.len = load i64, ptr<%__vector_i32> %6
  %7 = getelementptr %__vector_i32, ptr<%__vector_i32> %items.addr, i32 0, i32 0
  %vec.data = load ptr<i32>, ptr<%__vector_i32> %7
  %vec.index.addr = alloca i64
  store i64 0, ptr<i64> %vec.index.addr
  br label %vec.cond.11_4
vec.cond.11_4:
  %8 = load i64, ptr<i64> %vec.index.addr
  %9 = icmp slt i64 %8, %vec.len
  br i1 %9, label %vec.body.11_4, label %vec.end.11_4
vec.body.11_4:
  %10 = load i64, ptr<i64> %vec.index.addr
  %11 = getelementptr inbounds i32, ptr<i32> %vec.data, i64 %10
  %item.addr = alloca i32
  %12 = load i32, ptr<i32> %11
  store i32 %12, ptr<i32> %item.addr
  %13 = getelementptr inbounds [9 x i8], ptr<[9 x i8]> %.str.2, i32 0, i32 0
  %14 = call i32 @printf(ptr<[9 x i8]> %13)
  br label %vec.step.11_4
vec.step.11_4:
  %15 = load i64, ptr<i64> %vec.index.addr
  %16 = add i64 %15, 1
  store i64 %16, ptr<i64> %vec.index.addr
  br label %vec.cond.11_4
vec.end.11_4:
  %17 = getelementptr inbounds [12 x i8], ptr<[12 x i8]> %.str.3, i32 0, i32 0
  %18 = call i32 @printf(ptr<[12 x i8]> %17)
  %19 = trunc i64 0 to i32
  ret i32 %19
}
