@.str.0 = external constant [7 x i8] [i8 72, i8 101, i8 108, i8 108, i8 111, i8 10, i8 0]

declare external i32 @printf(ptr<u8>, ...)

define external i32 @main() {
entry:
  %0 = getelementptr inbounds [7 x i8], ptr<[7 x i8]> %.str.0, i32 0, i32 0
  %1 = call i32 @printf(ptr<[7 x i8]> %0)
  %2 = trunc i64 0 to i32
  ret i32 %2
}
