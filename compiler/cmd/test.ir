define external { i32, i1 } @divide(i32 %a, i32 %b) {
entry:
  %a.addr = alloca i32
  store i32 %a, ptr<i32> %a.addr
  %b.addr = alloca i32
  store i32 %b, ptr<i32> %b.addr
  %0 = load i32, ptr<i32> %b.addr
  %1 = icmp eq i32 %0, 0
  br i1 %1, label %if.then.3_4, label %if.next.3_4
if.end.3_4:
  %5 = load i32, ptr<i32> %a.addr
  %6 = load i32, ptr<i32> %b.addr
  %7 = sdiv i32 %5, %6
  %8 = insertvalue { i32, i1 } zeroinitializer, i32 %7, 0
  %9 = insertvalue { i32, i1 } %8, i1 1, 1
  ret { i32, i1 } %9
if.then.3_4:
  %2 = trunc i64 0 to i32
  %3 = insertvalue { i32, i1 } zeroinitializer, i32 %2, 0
  %4 = insertvalue { i32, i1 } %3, i1 0, 1
  ret { i32, i1 } %4
if.next.3_4:
  br label %if.end.3_4
}

define external i32 @main() {
entry:
  %10 = trunc i64 10 to i32
  %11 = trunc i64 2 to i32
  %12 = call { i32, i1 } @divide(i32 %10, i32 %11)
  %tuple.destruct.temp = alloca { i32, i1 }
  store { i32, i1 } %12, ptr<{ i32, i1 }> %tuple.destruct.temp
  %13 = getelementptr inbounds { i32, i1 }, ptr<{ i32, i1 }> %tuple.destruct.temp, i32 0, i32 0
  %14 = load i32, ptr<{ i32, i1 }> %13
  %result.addr = alloca i32
  store i32 %14, ptr<i32> %result.addr
  %15 = getelementptr inbounds { i32, i1 }, ptr<{ i32, i1 }> %tuple.destruct.temp, i32 0, i32 1
  %16 = load i1, ptr<{ i32, i1 }> %15
  %ok.addr = alloca i1
  store i1 %16, ptr<i1> %ok.addr
  %17 = load i1, ptr<i1> %ok.addr
  br i1 %17, label %if.then.11_4, label %if.next.11_4
if.end.11_4:
  %21 = trunc i64 1 to i32
  ret i32 %21
if.then.11_4:
  %18 = load i32, ptr<i32> %result.addr
  %19 = icmp eq i32 %18, 5
  br i1 %19, label %if.then.12_8, label %if.next.12_8
if.next.11_4:
  br label %if.end.11_4
if.end.12_8:
  br label %if.end.11_4
if.then.12_8:
  %20 = trunc i64 0 to i32
  ret i32 %20
if.next.12_8:
  br label %if.end.12_8
}
