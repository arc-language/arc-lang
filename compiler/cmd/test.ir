define external i32 @main() {
entry:
  %x.addr = alloca i64
  store i64 10, ptr<i64> %x.addr
  %y.addr = alloca i64
  store i64 20, ptr<i64> %y.addr
}

define external void @swap<i32>(ptr<i32> %a, ptr<i32> %b) {
entry:
  %a.addr = alloca ptr<i32>
  store ptr<i32> %a, ptr<ptr<i32>> %a.addr
  %b.addr = alloca ptr<i32>
  store ptr<i32> %b, ptr<ptr<i32>> %b.addr
  %0 = load ptr<i32>, ptr<ptr<i32>> %a.addr
  %1 = load i32, ptr<i32> %0
  %tmp.addr = alloca i32
  store i32 %1, ptr<i32> %tmp.addr
  %2 = load ptr<i32>, ptr<ptr<i32>> %a.addr
  %3 = load ptr<i32>, ptr<ptr<i32>> %b.addr
  %4 = load i32, ptr<i32> %3
  store i32 %4, ptr<i32> %2
  %5 = load ptr<i32>, ptr<ptr<i32>> %b.addr
  %6 = load i32, ptr<i32> %tmp.addr
  store i32 %6, ptr<i32> %5
  ret void
  call void @swap<i32>(ptr<i64> %x.addr, ptr<i64> %y.addr)
  %7 = load i64, ptr<i64> %x.addr
  %8 = icmp eq i64 %7, 20
  br i1 %8, label %if.then.13_4, label %if.next.13_4
if.end.13_4:
  ret i64 1
if.then.13_4:
  ret i64 0
if.next.13_4:
  br label %if.end.13_4
}
