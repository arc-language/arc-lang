%Point = type { i32, i32 }

define external i32 @Point_sum(%Point %p) {
entry:
  %p.addr = alloca %Point
  store %Point %p, ptr<%Point> %p.addr
  %0 = getelementptr %Point, ptr<%Point> %p.addr, i32 0, i32 0
  %1 = load i32, ptr<%Point> %0
  %2 = getelementptr %Point, ptr<%Point> %p.addr, i32 0, i32 1
  %3 = load i32, ptr<%Point> %2
  %4 = add i32 %1, %3
  ret i32 %4
}

define external i32 @main() {
entry:
  %5 = trunc i64 10 to i32
  %6 = insertvalue %Point zeroinitializer, i32 %5, 0
  %7 = trunc i64 20 to i32
  %8 = insertvalue %Point %6, i32 %7, 1
  %p.addr = alloca %Point
  store %Point %8, ptr<%Point> %p.addr
  %9 = load %Point, ptr<%Point> %p.addr
  %10 = call i32 @Point_sum(%Point %9)
  %s.addr = alloca i32
  store i32 %10, ptr<i32> %s.addr
  %11 = load i32, ptr<i32> %s.addr
  %12 = icmp eq i32 %11, 30
  br i1 %12, label %if.then.14_4, label %if.next.14_4
if.end.14_4:
  %14 = trunc i64 1 to i32
  ret i32 %14
if.then.14_4:
  %13 = trunc i64 0 to i32
  ret i32 %13
if.next.14_4:
  br label %if.end.14_4
}
