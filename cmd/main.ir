@.str.0 = external constant [5 x i8] [i8 37, i8 100, i8 92, i8 110, i8 0]

declare external i32 @printf(ptr<i64>, ...)

define external i32 @main() {
entry:
  %0 = icmp eq i64 0, 1000
  br i1 %0, label %if.then, label %if.end
if.then:
  %1 = getelementptr inbounds [5 x i8], ptr<[5 x i8]> @.str.0, i32 0, i32 0
  %2 = call i32 @printf(ptr<[5 x i8]> %1, i64 0)
  br label %if.end
if.end:
  %3 = trunc i64 0 to i32
  ret i32 %3
}
