define external i32 @main() {
entry:
  br label %loop.cond
loop.cond:
  br i1 0, label %loop.body, label %loop.end
loop.body:
  %0 = icmp ne i64 0, zeroinitializer
  br i1 %0, label %if.then, label %if.end
loop.post:
  br label %loop.cond
loop.end:
  %1 = trunc i64 0 to i32
  ret i32 %1
if.then:
  br label %loop.end
if.end:
  br label %loop.post
}
