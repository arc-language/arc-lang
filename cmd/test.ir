define external i32 @main() {
entry:
  %arr.addr = alloca [5 x i32]
  %0 = getelementptr inbounds [5 x i32], ptr<[5 x i32]> %arr.addr, i32 0, i32 0
  store i32 10, ptr<[5 x i32]> %0
  %1 = getelementptr inbounds [5 x i32], ptr<[5 x i32]> %arr.addr, i32 0, i32 1
  store i32 20, ptr<[5 x i32]> %1
  %2 = getelementptr inbounds [5 x i32], ptr<[5 x i32]> %arr.addr, i32 0, i32 2
  store i32 30, ptr<[5 x i32]> %2
  %3 = getelementptr inbounds [5 x i32], ptr<[5 x i32]> %arr.addr, i32 0, i32 3
  store i32 40, ptr<[5 x i32]> %3
  %4 = getelementptr inbounds [5 x i32], ptr<[5 x i32]> %arr.addr, i32 0, i32 4
  store i32 50, ptr<[5 x i32]> %4
  %5 = trunc i64 0 to i32
  %sum.addr = alloca i32
  store i32 %5, ptr<i32> %sum.addr
  %arr.index.addr = alloca i64
  store i64 0, ptr<i64> %arr.index.addr
  br label %arr.cond.8_4
arr.cond.8_4:
  %6 = load i64, ptr<i64> %arr.index.addr
  %7 = icmp slt i64 %6, 5
  br i1 %7, label %arr.body.8_4, label %arr.end.8_4
arr.body.8_4:
  %8 = load i64, ptr<i64> %arr.index.addr
  %9 = getelementptr inbounds [5 x i32], ptr<[5 x i32]> %arr.addr, i64 0, i64 %8
  %x.addr = alloca i32
  %10 = load i32, ptr<[5 x i32]> %9
  store i32 %10, ptr<i32> %x.addr
  %11 = load i32, ptr<i32> %x.addr
  %12 = load i32, ptr<i32> %sum.addr
  %13 = add i32 %12, %11
  store i32 %13, ptr<i32> %sum.addr
  br label %arr.step.8_4
arr.step.8_4:
  %14 = load i64, ptr<i64> %arr.index.addr
  %15 = add i64 %14, 1
  store i64 %15, ptr<i64> %arr.index.addr
  br label %arr.cond.8_4
arr.end.8_4:
  %16 = load i32, ptr<i32> %sum.addr
  %17 = icmp eq i32 %16, 150
  br i1 %17, label %if.then.13_4, label %if.next.13_4
if.end.13_4:
  %19 = trunc i64 1 to i32
  ret i32 %19
if.then.13_4:
  %18 = trunc i64 0 to i32
  ret i32 %18
if.next.13_4:
  br label %if.end.13_4
}
